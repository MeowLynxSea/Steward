{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Steward",
  "version": "0.1.0",
  "identifier": "ai.steward.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix ui run build",
    "beforeBuildCommand": "npm --prefix ui run build",
    "frontendDist": "static"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Steward",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true,
        "decorations": false,
        "transparent": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
